{
  "name": "filezen-tests-non-fonctionnels",
  "version": "1.0.0",
  "description": "Tests non-fonctionnels FileZen — Performance (k6) et Sécurité (OWASP ZAP / jest)",
  "type": "commonjs",
  "scripts": {
    "test:perf:smoke":         "k6 run tests/performance/smoke.test.js",
    "test:perf:load":          "k6 run tests/performance/load.test.js",
    "test:perf:load:dashboard":"k6 run --out web-dashboard tests/performance/load.test.js",
    "test:perf:load:grafana":  "k6 run --out influxdb=http://localhost:8086/k6 tests/performance/load.test.js",
    "test:perf:stress":        "k6 run tests/performance/stress.test.js",
    "test:perf:spike":         "k6 run tests/performance/spike.test.js",
    "test:security":      "jest --testPathPattern=tests/security --verbose",
    "test:all":           "npm run test:security",

    "allure:generate":    "allure generate allure-results --clean -o allure-report",
    "allure:open":        "allure open allure-report",
    "allure:serve":       "allure serve allure-results"
  },
  "devDependencies": {
    "allure-commandline": "^2.30.0",
    "allure-jest":        "^3.0.0",
    "axios":              "^1.7.2",
    "jest":               "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "notes": {
    "k6": "Installer k6 séparément : https://k6.io/docs/getting-started/installation/",
    "zap": "OWASP ZAP optionnel pour scan dynamique complet"
  }
}
